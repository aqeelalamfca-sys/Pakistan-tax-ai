# ============================================================
# Pakistan Tax AI — Production Environment Variables
# Copy to .env.production on VPS: /opt/pakistan-tax-ai/.env.production
# NEVER commit real secrets to Git
# ============================================================

# --- Database ---
DB_NAME=pakistan_tax_ai
DB_USER=taxai_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://taxai_user:CHANGE_ME@pakistan-tax-ai-db:5432/pakistan_tax_ai

# --- Security ---
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
SESSION_SECRET=CHANGE_ME_ANOTHER_RANDOM_STRING
ENCRYPTION_MASTER_KEY=CHANGE_ME_32_BYTE_HEX_KEY

# --- App ---
NODE_ENV=production
PORT=8080
NGINX_PORT=4080
DOMAIN=tax.auditwise.tech

# --- AI (optional) ---
AI_PROVIDER=openai
OPENAI_API_KEY=

# --- File Storage ---
UPLOAD_DIR=/app/uploads
VAULT_DIR=/app/vault

# --- Redis (optional, for future session store) ---
REDIS_URL=

# --- VPS Deployment (used by devops scripts, not by app) ---
VPS_HOST=YOUR_VPS_IP_OR_HOSTNAME
VPS_USER=root
APP_PATH=/opt/pakistan-tax-ai

# --- GitHub (for devops/push.sh if using token auth) ---
# GITHUB_PERSONAL_ACCESS_TOKEN=
